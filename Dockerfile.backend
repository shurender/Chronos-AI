# Chronos backend (FastAPI). CPU-only image.
# Note: installs the CPU torch stack (sentence-transformers) — the build is
# large. Set EMBEDDING_PROVIDER=mock to skip model downloads at runtime.
FROM python:3.11-slim

WORKDIR /app

# System deps kept minimal; chromadb/torch wheels are prebuilt.
RUN apt-get update && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-cpu.txt ./
RUN pip install --no-cache-dir -r requirements-cpu.txt

COPY backend ./backend

# Data stores live under /data (mount a volume). Overridable via env.
ENV DATA_DIR=/data \
    CHROMA_DB_PATH=/data/chroma_db \
    GRAPH_PATH=/data/graph.gpickle \
    LLM_PROVIDER=mock \
    EVIDENCE_PROVIDER=demo \
    ANONYMIZED_TELEMETRY=false \
    DEMO_MODE=true

EXPOSE 8000

CMD ["uvicorn", "backend.api:app", "--host", "0.0.0.0", "--port", "8000"]
