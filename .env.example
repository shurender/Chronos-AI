# Copy to .env and adjust. All values are optional — sane defaults are baked in.

# Optional: enables Groq-backed LLM extraction + Future Self chat. Leave blank
# to run fully in mock/deterministic mode (no paid API).
GROQ_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
TAVILY_API_KEY=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/connectors/github/callback
GITHUB_TOKEN=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/connectors/slack/callback

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/connectors/notion/callback
NOTION_VERSION=2026-03-11
NOTION_TOKEN=

CONNECTOR_TOKEN_STORE=local
CONNECTOR_ENCRYPTION_KEY=dev-only-local-key

# Chat provider: groq | fireworks | ollama | vllm | mock
LLM_PROVIDER=fireworks
REQUIRE_LIVE_LLM=false
# Evidence provider: demo | uploaded | tavily | web | hybrid
EVIDENCE_PROVIDER=hybrid
# Embeddings: sentence_transformers | ollama | openai_like | mock
EMBEDDING_PROVIDER=sentence_transformers
# Agent council: deterministic | llm | hybrid
AGENT_MODE=deterministic

DEMO_MODE=false

# Comma-separated allowed origins for the frontend.
CORS_ORIGINS=http://localhost:5173

# Local data locations. DATA_DIR relocates the default graph + Chroma stores.
DATA_DIR=./data
# Optional direct overrides (CHROMA_PATH remains a supported legacy alias).
# CHROMA_DB_PATH=./data/chroma_db
# GRAPH_PATH=./data/graph.gpickle

# Disable local Chroma product telemetry.
ANONYMIZED_TELEMETRY=False
