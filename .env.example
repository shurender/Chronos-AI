# Copy to .env and adjust. All values are optional — sane defaults are baked in.

# Optional: enables Groq-backed LLM extraction + Future Self chat. Leave blank
# to run fully in mock/deterministic mode (no paid API).
GROQ_API_KEY=
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
TAVILY_API_KEY=

# Chat provider: groq | fireworks | ollama | vllm | mock
LLM_PROVIDER=fireworks
# Evidence provider: demo | uploaded | tavily | web | hybrid
EVIDENCE_PROVIDER=hybrid
# Embeddings: sentence_transformers | ollama | openai_like | mock
EMBEDDING_PROVIDER=sentence_transformers
# Agent council: deterministic | llm | hybrid
AGENT_MODE=deterministic

DEMO_MODE=true

# Comma-separated allowed origins for the frontend.
CORS_ORIGINS=http://localhost:5173

# Local data locations. DATA_DIR relocates graph + chroma stores together.
CHROMA_PATH=./chroma_db
DATA_DIR=./data
